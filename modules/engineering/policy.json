{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "EngineeringS3Access",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::frazycorp-engineering-data-2024frazy",
        "arn:aws:s3:::frazycorp-engineering-data-2024frazy/*"
      ]
    },
    {
      "Sid": "EngineeringDynamoDB",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:PutItem",
        "dynamodb:Query",
        "dynamodb:Scan",
        "dynamodb:UpdateItem",
        "dynamodb:DeleteItem"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:*:table/engineering-db"
    }
  ]
}