{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Sid": "FinanceS3ReadOnly",
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:ListBucket"
      ],
      "Resource": [
        "arn:aws:s3:::frazycorp-finance-reports-2024frazy",
        "arn:aws:s3:::frazycorp-finance-reports-2024frazy/*"
      ]
    },
    {
      "Sid": "FinanceDynamoDB",
      "Effect": "Allow",
      "Action": [
        "dynamodb:GetItem",
        "dynamodb:Query",
        "dynamodb:Scan"
      ],
      "Resource": "arn:aws:dynamodb:us-east-1:*:table/finance-db"
    }
  ]
}